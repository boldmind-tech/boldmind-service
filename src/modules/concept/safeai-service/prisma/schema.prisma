
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("SAFEAI_SERVICE_DATABASE_URL")
  extensions = [postgis]
}

// ==================== INCIDENTS ====================
model Incident {
  id            String   @id @default(uuid())
  reporterId    String?  @db.Uuid // Optional for anonymous reports
  
  // Incident Details
  incidentType  IncidentType
  description   String   @db.Text
  
  // Location (PostGIS)
  latitude      Decimal  @db.Decimal(10, 8)
  longitude     Decimal  @db.Decimal(11, 8)
  address       String?  @db.Text
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(100)
  
  // Severity & Status
  severity      Severity @default(MEDIUM)
  status        IncidentStatus @default(REPORTED)
  
  // Priority (AI-calculated)
  priorityScore Int      @default(50) // 0-100
  
  // Dates
  incidentDate  DateTime @default(now())
  reportedAt    DateTime @default(now())
  resolvedAt    DateTime?
  
  // Evidence
  evidenceUrls  String[] @db.Text
  
  // Witnesses (JSON)
  witnesses     Json?    @db.JsonB
  
  // Assignment
  assignedOfficerId String? @db.Uuid
  
  // Officer Notes
  officerNotes  String?  @db.Text
  
  // Anonymous Reporting
  isAnonymous   Boolean  @default(false)
  reporterContact String? @db.VarChar(255) // Encrypted
  
  // AI Analysis
  aiAnalysis    Json?    @db.JsonB
  
  // Metadata
  metadata      Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  officer       Officer?  @relation("AssignedIncidents", fields: [assignedOfficerId], references: [id])
  updates       IncidentUpdate[]
  verifications IncidentVerification[]
  
  @@index([incidentType])
  @@index([status])
  @@index([severity])
  @@index([reportedAt])
  @@index([city, state])
  @@index([latitude, longitude])
  @@map("incidents")
}

enum IncidentType {
  THEFT
  ROBBERY
  BURGLARY
  ASSAULT
  DOMESTIC_VIOLENCE
  KIDNAPPING
  ACCIDENT
  FIRE
  MEDICAL_EMERGENCY
  SUSPICIOUS_ACTIVITY
  MISSING_PERSON
  FRAUD
  CYBERCRIME
  DRUG_RELATED
  NOISE_COMPLAINT
  TRESPASSING
  VANDALISM
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  EMERGENCY
}

enum IncidentStatus {
  REPORTED
  VERIFIED
  INVESTIGATING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  FALSE_REPORT
}

// ==================== INCIDENT UPDATES ====================
model IncidentUpdate {
  id          String   @id @default(uuid())
  incidentId  String   @db.Uuid
  
  // Update Details
  updateType  UpdateType
  message     String   @db.Text
  
  // Who updated
  updatedBy   String   @db.Uuid // Officer ID
  updatedByRole String @db.VarChar(50)
  
  // Attachments
  attachments String[] @db.Text
  
  // Metadata
  createdAt   DateTime @default(now())
  
  // Relations
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  
  @@index([incidentId])
  @@index([createdAt])
  @@map("incident_updates")
}

enum UpdateType {
  STATUS_CHANGE
  ASSIGNMENT
  EVIDENCE_ADDED
  NOTE_ADDED
  RESOLUTION
}

// ==================== INCIDENT VERIFICATION ====================
model IncidentVerification {
  id          String   @id @default(uuid())
  incidentId  String   @db.Uuid
  
  // Verifier
  verifiedBy  String   @db.Uuid
  
  // Verification Details
  isVerified  Boolean
  confidence  Int      @db.SmallInt // 0-100
  notes       String?  @db.Text
  
  // Additional Evidence
  evidenceUrls String[] @db.Text
  
  verifiedAt  DateTime @default(now())
  
  // Relations
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  
  @@index([incidentId])
  @@map("incident_verifications")
}

// ==================== OFFICERS ====================
model Officer {
  id            String   @id @default(uuid())
  userId        String   @unique @db.Uuid
  
  // Officer Details
  badgeNumber   String   @unique @db.VarChar(50)
  rank          String?  @db.VarChar(100)
  department    String?  @db.VarChar(100)
  station       String?  @db.VarChar(255)
  
  // Contact
  phone         String?  @db.VarChar(50)
  emergencyContact String? @db.VarChar(50)
  
  // Assignment Area (GeoJSON polygon)
  assignedArea  Json?    @db.JsonB
  
  // Current Location (for real-time tracking)
  lastLatitude  Decimal? @db.Decimal(10, 8)
  lastLongitude Decimal? @db.Decimal(11, 8)
  lastSeenAt    DateTime?
  
  // Status
  isActive      Boolean  @default(true)
  isOnDuty      Boolean  @default(false)
  
  // Verification
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  verifiedBy    String?  @db.Uuid
  
  // Stats
  incidentsResolved Int   @default(0)
  responseTime   Int?     // Average in minutes
  rating         Decimal? @db.Decimal(3, 2)
  
  // Metadata
  metadata      Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  assignedIncidents Incident[] @relation("AssignedIncidents")
  patrolLogs        PatrolLog[]
  responses         EmergencyResponse[]
  
  @@index([badgeNumber])
  @@index([isActive])
  @@index([station])
  @@map("officers")
}

// ==================== PATROL LOGS ====================
model PatrolLog {
  id          String   @id @default(uuid())
  officerId   String   @db.Uuid
  
  // Time
  startTime   DateTime
  endTime     DateTime?
  
  // Route (Array of coordinates)
  route       Json?    @db.JsonB
  
  // Stats
  distanceKm  Decimal? @db.Decimal(8, 2)
  incidentsResponded Int @default(0)
  
  // Notes
  notes       String?  @db.Text
  
  // Checkpoints (locations visited)
  checkpoints Json?    @db.JsonB
  
  createdAt   DateTime @default(now())
  
  // Relations
  officer     Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  
  @@index([officerId])
  @@index([startTime])
  @@map("patrol_logs")
}

// ==================== EMERGENCY RESPONSE ====================
model EmergencyResponse {
  id          String   @id @default(uuid())
  incidentId  String?  @db.Uuid
  
  // Emergency Details
  emergencyType EmergencyType
  description String   @db.Text
  
  // Location
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  address     String?  @db.Text
  
  // Caller Info
  callerPhone String?  @db.VarChar(50)
  callerName  String?  @db.VarChar(255)
  
  // Response
  status      ResponseStatus @default(PENDING)
  priority    Int      @db.SmallInt // 1-5
  
  // Officers Dispatched
  dispatchedOfficers String[] @db.Uuid
  
  // Response Times
  reportedAt  DateTime @default(now())
  dispatchedAt DateTime?
  arrivedAt   DateTime?
  resolvedAt  DateTime?
  
  // Response Details
  responseNotes String? @db.Text
  outcome       String? @db.Text
  
  // Metadata
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  officers    Officer[] @relation(references: [id])
  
  @@index([status])
  @@index([priority])
  @@index([reportedAt])
  @@map("emergency_responses")
}

enum EmergencyType {
  EMERGENCY_911
  FIRE
  MEDICAL
  POLICE
  RESCUE
  OTHER
}

enum ResponseStatus {
  PENDING
  DISPATCHED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

// ==================== SAFETY ALERTS ====================
model SafetyAlert {
  id          String   @id @default(uuid())
  
  // Alert Details
  alertType   AlertType
  title       String   @db.VarChar(255)
  message     String   @db.Text
  severity    Severity
  
  // Location (for geo-targeted alerts)
  targetAreas Json?    @db.JsonB // Array of polygons
  
  // Radius (for point-based alerts)
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  radiusKm    Decimal? @db.Decimal(6, 2)
  
  // Publishing
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  
  // Source
  issuedBy    String   @db.Uuid
  issuedByRole String  @db.VarChar(50)
  
  // Stats
  viewCount   Int      @default(0)
  shareCount  Int      @default(0)
  
  // Metadata
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
  @@index([severity])
  @@index([publishedAt])
  @@map("safety_alerts")
}

enum AlertType {
  CRIME_ALERT
  MISSING_PERSON
  WANTED_PERSON
  TRAFFIC_ALERT
  WEATHER_WARNING
  COMMUNITY_NOTICE
  SAFETY_TIP
  CURFEW
  EMERGENCY
}

// ==================== CRIME HOTSPOTS ====================
model CrimeHotspot {
  id          String   @id @default(uuid())
  
  // Location
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  area        String   @db.VarChar(255)
  city        String   @db.VarChar(100)
  state       String   @db.VarChar(100)
  
  // Crime Stats
  crimeType   IncidentType
  incidentCount Int    @default(0)
  
  // Time Period
  periodStart DateTime
  periodEnd   DateTime
  
  // Risk Score (AI-calculated)
  riskScore   Int      @db.SmallInt // 0-100
  
  // Analysis
  timePatterns Json?   @db.JsonB // Peak hours/days
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([city, state])
  @@index([riskScore])
  @@map("crime_hotspots")
}

// ==================== POLICE STATIONS ====================
model PoliceStation {
  id          String   @id @default(uuid())
  
  // Station Details
  name        String   @db.VarChar(255)
  stationCode String   @unique @db.VarChar(50)
  
  // Location
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  address     String   @db.Text
  city        String   @db.VarChar(100)
  state       String   @db.VarChar(100)
  
  // Contact
  phone       String?  @db.VarChar(50)
  email       String?  @db.VarChar(255)
  
  // Service Area
  serviceArea Json?    @db.JsonB // GeoJSON polygon
  
  // Capacity
  officerCount Int     @default(0)
  vehicleCount Int     @default(0)
  
  // Status
  isOperational Boolean @default(true)
  
  // Metadata
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([city, state])
  @@map("police_stations")
}

// ==================== WANTED PERSONS ====================
model WantedPerson {
  id          String   @id @default(uuid())
  
  // Person Details
  name        String   @db.VarChar(255)
  alias       String[] @db.Text
  age         Int?
  gender      Gender?
  
  // Physical Description
  height      String?  @db.VarChar(50)
  weight      String?  @db.VarChar(50)
  complexion  String?  @db.VarChar(50)
  
  // Crime Details
  charges     String[] @db.Text
  description String   @db.Text
  
  // Photos
  photoUrls   String[] @db.Text
  
  // Last Known Location
  lastSeenLocation String? @db.VarChar(255)
  lastSeenDate     DateTime?
  
  // Status
  status      WantedStatus @default(ACTIVE)
  priority    Int      @db.SmallInt // 1-5
  
  // Reward
  rewardAmount Decimal? @db.Decimal(10, 2)
  
  // Contact
  tiplinePhone String?  @db.VarChar(50)
  
  // Stats
  viewCount   Int      @default(0)
  tipCount    Int      @default(0)
  
  // Metadata
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([priority])
  @@map("wanted_persons")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum WantedStatus {
  ACTIVE
  CAPTURED
  CLEARED
  INACTIVE
}